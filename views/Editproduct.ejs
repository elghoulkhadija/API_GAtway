<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Modifier Produit</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center p-8">

  <div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-md">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
      <a href="/products"
         class="text-gray-400 hover:text-gray-600 transition">
        ← Retour
      </a>
      <h1 class="text-2xl font-bold text-gray-800">✏️ Modifier le Produit</h1>
    </div>

    <form action="/products/update/<%= product._id %>?_method=PUT" method="POST" class="space-y-5">

      <!-- Nom -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Nom du produit
        </label>
        <input type="text"
               name="name"
               value="<%= product.name %>"
               required
               class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 transition"/>
      </div>

      <!-- Prix -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Prix (DH)
        </label>
        <input type="number"
               name="price"
               value="<%= product.price %>"
               min="0"
               step="0.01"
               required
               class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 transition"/>
      </div>

      <!-- Description -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Description
        </label>
        <textarea name="description"
                  rows="3"
                  class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 transition">
          <%= product.description !== '----' ? product.description : '' %>
        </textarea>
      </div>

      <!-- Boutons -->
      <div class="flex gap-3 pt-2">
        <button type="submit"
                class="flex-1 bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 rounded-lg transition duration-200">
          💾 Enregistrer
        </button>
        <a href="/products"
           class="flex-1 text-center bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-2 rounded-lg transition duration-200">
          Annuler
        </a>
      </div>

    </form>
  </div>

</body>
</html>